                <mxCell id="title" value="MULTIPLICATION: WHY FIXED-POINT VS FLOAT SPEEDUPS VARY BY HARDWARE" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=20;fontStyle=1;fontColor=#2D3748;" parent="1" vertex="1">
