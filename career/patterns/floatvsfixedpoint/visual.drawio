                <mxCell id="box_f1" value="&lt;b&gt;Hardware FPU&lt;/b&gt;&lt;br&gt;&lt;br&gt;1 Native FMUL&lt;br&gt;Instruction&lt;br&gt;&lt;br&gt;&lt;i&gt;(FAST)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;strokeWidth=2;fontColor=#155724;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="60" y="190" width="140" height="120" as="geometry"/>
                </mxCell>
