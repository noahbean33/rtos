                    <mxGeometry x="220" y="190" width="140" height="120" as="geometry"/>
                </mxCell>

                <mxCell id="sum1" value="&lt;b style='font-size:20px;'&gt;0.78x Speedup&lt;/b&gt;&lt;br&gt;&lt;b style='color:#C53030'&gt;(Float is Faster)&lt;/b&gt;&lt;hr&gt;Native hardware FPU outperforms multi-instruction integer math." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7FAFC;strokeColor=#A0AEC0;strokeWidth=2;fontColor=#1A202C;fontFamily=Helvetica;align=center;verticalAlign=top;spacingTop=15;spacingLeft=10;spacingRight=10;" parent="1" vertex="1">
